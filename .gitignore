# AIF Otomasyon Sistemi - Git Ignore Dosyası

# Hassas dosyalar
config/database.local.php
config/app.local.php
.env

# Dosya yüklemeleri
uploads/*
!uploads/.gitkeep

# Log dosyaları
*.log
logs/

# IDE ve editör dosyaları
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Geçici dosyalar
*.tmp
*.temp
*.cache

# Veritabanı yedekleri
*.sql.gz
*.sql.bak
backups/

# Vendor dizini (eğer composer kullanılıyorsa)
/vendor/

# Node modules (eğer npm kullanılıyorsa)
node_modules/
package-lock.json

# Build dosyaları
dist/
build/

